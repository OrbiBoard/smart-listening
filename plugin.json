{
  "id": "smart-listening",
  "name": "智慧听力",
  "version": "0.2.0",
  "author": "OrbiBoard",
  "icon": "ri-headphone-line",
  "description": "智能音频播放管理，支持播放列表、播放速度调节、定时播放等功能",
  "actions": [
    {
      "id": "openSmartListening",
      "icon": "ri-headphone-line",
      "text": "打开智慧听力",
      "target": "openSmartListening"
    }
  ],
  "variables": [
    "timeISO",
    "currentAudioName",
    "todayCount"
  ],
  "dependencies": [
    "ui-lowbar",
    "notify-plugin"
  ],
  "features": [
    "音频文件浏览与管理",
    "播放列表管理（拖拽排序）",
    "播放速度调节（0.5x - 2.0x）",
    "定时播放功能",
    "已听状态追踪",
    "主题自适应"
  ]
}
